# Database (load from host environment variables)
# DATABASE_URL is constructed from: postgresql://DB_USER:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME
# These are set on the VPS host, not in .env
# See: DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASSWORD environment variables

# API Configuration
API_PORT=3000
NODE_ENV=development

# JWT (generate secure secret before deploying)
JWT_SECRET=your_jwt_secret_here_change_in_production

# Email (Hostinger SMTP)
# HOSTINGER_SMTP_HOST=...
# HOSTINGER_SMTP_PORT=...
# HOSTINGER_SMTP_USER=...
# HOSTINGER_SMTP_PASSWORD=...

# GitHub (for API integrations)
# GITHUB_API_TOKEN=... (set on VPS)

# Logging
LOG_LEVEL=info
