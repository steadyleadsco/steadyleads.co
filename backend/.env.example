# ============================================
# ENVIRONMENT VARIABLES FOR DOCKER COMPOSE
# ============================================
# Note: These are loaded from VPS host environment
# Set them before running: docker-compose up
# Example: export DB_PASSWORD="..." && docker-compose up

# Database Connection (set on VPS host)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=openclaw
DB_USER=openclaw_dba
DB_PASSWORD=your_secure_password_here

# API Configuration
NODE_ENV=production
API_PORT=3000

# JWT Secret (generate a secure random string)
JWT_SECRET=your_secure_jwt_secret_change_in_production

# GitHub API (optional, for integrations)
GITHUB_API_TOKEN=your_github_api_token_here

# Telegram Bot (optional, for integrations)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Email / SMTP (future, for notifications)
# HOSTINGER_SMTP_HOST=smtp.hostinger.com
# HOSTINGER_SMTP_PORT=465
# HOSTINGER_SMTP_USER=noreply@steadyleads.co
# HOSTINGER_SMTP_PASSWORD=your_smtp_password

# Logging
LOG_LEVEL=info

# ============================================
# HOW TO USE
# ============================================
# 1. Copy this file and set actual values:
#    cp .env.example .env
#
# 2. Set secure values:
#    - JWT_SECRET: `openssl rand -base64 32`
#    - DB_PASSWORD: From your postgres setup
#    - GITHUB_API_TOKEN: From GitHub settings
#    - TELEGRAM_BOT_TOKEN: From BotFather
#
# 3. Source before docker-compose:
#    export $(cat .env | xargs)
#    docker-compose up -d
#
# Or use .env directly (docker-compose loads it):
#    docker-compose up -d
#
# ============================================
